{
  "name": "@undiff/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify backend — webhooks, orchestration, API",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/env": "^5.0.0",
    "@undiff/shared": "workspace:*",
    "ai": "^4.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.0",
    "nanoid": "^5.0.0",
    "octokit": "^4.1.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.30.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
