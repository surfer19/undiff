{
  "name": "undiff",
  "version": "0.1.0",
  "private": true,
  "description": "Undiff - Multi-Agent Solution Explorer for GitHub Code Review",
  "scripts": {
    "dev": "turbo dev",
    "dev:up": "podman compose --profile tunnel up -d --wait && turbo dev",
    "dev:down": "podman compose --profile tunnel down",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate --filter=@undiff/api",
    "db:migrate": "turbo db:migrate --filter=@undiff/api",
    "db:studio": "pnpm --filter @undiff/api db:studio"
  },
  "keywords": [
    "code-review",
    "github",
    "ai",
    "multi-agent"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.13",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "zod": "^3.25.76"
  }
}
