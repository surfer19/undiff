# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/next_review

# ─── Anthropic (via Vercel AI SDK) ───────────────────────────────────────────
ANTHROPIC_API_KEY=
AI_OPTIONS_MODEL=claude-3-5-haiku-latest
AI_BRANCH_MODEL=claude-3-5-haiku-latest
AI_OPTIONS_MAX_INPUT_CHARS=12000
AI_OPTIONS_MAX_TOKENS=900
AI_BRANCH_MAX_TOKENS=1200

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# ─── Webhook Tunnel (development only) ──────────────────────────────────────
SMEE_URL=https://smee.io/mbw9RYKJdW4Mzne
